APP__PROJECT_NAME=cinema-api
APP__DEBUG=false
APP__API_V1_PREFIX=/api/v1

ELASTICSEARCH__SCHEME=http
ELASTICSEARCH__HOST=elasticsearch
ELASTICSEARCH__PORT=9200
ELASTICSEARCH__REQUEST_TIMEOUT=5
ELASTICSEARCH__CONNECTIONS_PER_NODE=50
ELASTICSEARCH__MAX_RETRIES=2
ELASTICSEARCH__RETRY_ON_TIMEOUT=true
ELASTICSEARCH__MOVIES_INDEX=movies
ELASTICSEARCH__GENRES_INDEX=genres
ELASTICSEARCH__PERSONS_INDEX=persons
ELASTICSEARCH__USER=
ELASTICSEARCH__PASSWORD=

REDIS__HOST=redis
REDIS__PORT=6379
REDIS__PASSWORD=
REDIS__SOCKET_TIMEOUT=5
REDIS__DECODE_RESPONSES=true
REDIS__MAX_CONNECTIONS=1000
REDIS__CACHE_TTL=300

UVICORN__HOST=0.0.0.0
UVICORN__PORT=8000
UVICORN__RELOAD=false
UVICORN__WORKERS=4
UVICORN__BACKLOG=4096
UVICORN__LIMIT_CONCURRENCY=10000
UVICORN__TIMEOUT_KEEP_ALIVE=5

TEST_API__BASE_URL=http://api:8000
TEST_API__ASGI_BASE_URL=http://test
TEST_ELASTICSEARCH__URL=http://elasticsearch:9200
TEST_ELASTICSEARCH__MOVIES_INDEX=movies
TEST_ELASTICSEARCH__GENRES_INDEX=genres
TEST_ELASTICSEARCH__PERSONS_INDEX=persons
TEST_REDIS__URL=redis://redis:6379/0
TEST_WAIT__TIMEOUT=90
TEST_WAIT__INTERVAL=1
TEST_API_PORT=8000
TEST_ELASTICSEARCH_PORT=9200
TEST_REDIS_PORT=6379
TEST_UVICORN_WORKERS=1
TEST_UVICORN_LIMIT_CONCURRENCY=1000
TEST_ELASTICSEARCH_IMAGE=docker.elastic.co/elasticsearch/elasticsearch:8.17.3
TEST_REDIS_IMAGE=redis:7.2-alpine
TEST_ES_JAVA_OPTS=-Xms512m -Xmx512m
TEST_ELASTICSEARCH_HEALTHCHECK_URL=http://localhost:9200/_cluster/health
TEST_ES_HEALTHCHECK_INTERVAL=10s
TEST_ES_HEALTHCHECK_TIMEOUT=5s
TEST_ES_HEALTHCHECK_RETRIES=20
TEST_REDIS_HEALTHCHECK_INTERVAL=10s
TEST_REDIS_HEALTHCHECK_TIMEOUT=5s
TEST_REDIS_HEALTHCHECK_RETRIES=20
